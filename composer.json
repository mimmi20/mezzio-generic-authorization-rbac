{
  "name": "mimmi20/mezzio-generic-authorization-rbac",
  "description": "Provides a laminas-permissions-rbac adapter for mezzio-generic-authorization.",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "mezzio",
    "authorization",
    "middleware",
    "psr-7",
    "psr-15",
    "rbac"
  ],
  "authors": [
    {
      "name": "Thomas Müller",
      "homepage": "https://github.com/mimmi20",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/mimmi20/mezzio-generic-authorization-rbac",
  "support": {
    "issues": "https://github.com/mimmi20/mezzio-generic-authorization-rbac/issues",
    "source": "https://github.com/mimmi20/mezzio-generic-authorization-rbac"
  },
  "require": {
    "php": "~8.3.0 || ~8.4.0 || ~8.5.0 || ~8.6.0",
    "laminas/laminas-permissions-rbac": "^3.8.0",
    "mimmi20/mezzio-generic-authorization": "^4.0.3",
    "psr/container": "^1.1.2 || ^2.0.2",
    "psr/http-message": "^1.0.1 || ^2.0"
  },
  "require-dev": {
    "ext-ctype": "*",
    "ext-dom": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "ext-xml": "*",
    "ext-xmlwriter": "*",
    "ergebnis/composer-normalize": "^2.50.0",
    "infection/infection": "^0.32.6",
    "jbelien/phpstan-sarif-formatter": "^1.2.0",
    "laminas/laminas-servicemanager": "^4.5.0",
    "mimmi20/coding-standard": "^6.2.5",
    "nikic/php-parser": "^5.7.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.1.46",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpunit/phpunit": "^12.5.0",
    "rector/rector": "^2.4.0",
    "rector/type-perfect": "^2.1.2",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "symfony/process": "^7.3.4",
    "symplify/phpstan-rules": "^14.9.11",
    "tomasvotruba/cognitive-complexity": "^1.1.0",
    "tomasvotruba/type-coverage": "^2.1.0",
    "tomasvotruba/unused-public": "^2.2.0"
  },
  "conflict": {
    "container-interop/container-interop": "<1.2.0",
    "mezzio/mezzio-authorization-rbac": "*"
  },
  "suggest": {
    "laminas/laminas-servicemanager": "to use the factories"
  },
  "autoload": {
    "psr-4": {
      "Mimmi20\\Mezzio\\GenericAuthorization\\Rbac\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mimmi20\\Mezzio\\GenericAuthorization\\Rbac\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true
    },
    "lock": false,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "extra": {
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    },
    "laminas": {
      "config-provider": "Mimmi20\\Mezzio\\GenericAuthorization\\Rbac\\ConfigProvider"
    }
  }
}
